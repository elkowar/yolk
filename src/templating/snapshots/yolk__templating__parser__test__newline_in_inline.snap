        Inline {
            line: TaggedLine {
                left: "foo /* ",
                tag: "{< test\ntest >}",
                right: " */",
                full_line: [0..25]"foo /* {< test\ntest >} */",
            },
            expr: Transform(
                [10..20]"test\ntest ",
            ),
        },
    ],
)
